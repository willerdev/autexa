# Autexa Node API — build from repository root: docker build -f server/Dockerfile server
# Or from server/: docker build .

FROM node:22-alpine

WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm ci --omit=dev

COPY src ./src
COPY utils ./utils

ENV NODE_ENV=production
ENV PORT=8787
EXPOSE 8787

CMD ["node", "src/index.js"]
