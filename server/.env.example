# Copy to server/.env (never commit). Rotate any key that was ever pasted into chat or committed.

PORT=8787

# Google AI (Gemini) — server-side only
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
# Imagen bill preview in chat before create_dynamic_booking (paid tier). Set BOOKING_BILL_IMAGE=0 to skip image API.
GEMINI_IMAGEN_MODEL=imagen-4.0-fast-generate-001
BOOKING_BILL_IMAGE=

# Supabase: URL + anon for JWT verification; service_role for DB writes from this API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public base URL of this server (optional; booking pay uses v4 mobile money push, not hosted checkout).
PUBLIC_API_BASE_URL=http://localhost:8787

# Flutterwave v4 — OAuth only (https://developer.flutterwave.com/v4.0/docs/authentication)
FLUTTERWAVE_CLIENT_ID=
FLUTTERWAVE_CLIENT_SECRET=
# Sandbox API host: set FLUTTERWAVE_SANDBOX=1 (default base is production https://api.flutterwave.com).
FLUTTERWAVE_SANDBOX=
# Optional overrides:
# FLUTTERWAVE_V4_BASE_URL=https://developersandbox-api.flutterwave.com
# FLUTTERWAVE_TOKEN_URL=https://idp.flutterwave.com/realms/flutterwave/protocol/openid-connect/token
# Booking deposit is charged in UGX; deposit amount_cents are USD — set a realistic rate.
FLUTTERWAVE_BOOKING_USD_TO_UGX=3850
# Webhook “secret hash” (header verif-hash).
FLUTTERWAVE_SECRET_HASH=
FLUTTERWAVE_WEBHOOK_SKIP_VERIFY=
FLUTTERWAVE_STUB=

# Stripe (legacy; booking checkout uses Flutterwave). Webhook returns 410 unless STRIPE_WEBHOOK_ENABLED=1.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_ENABLED=

# Twilio SMS (transactional; optional). Set TWILIO_SMS_ENABLED=0 to keep in-app only.
# Rotate the auth token if it was ever exposed (e.g. pasted in chat).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# TWILIO_PHONE_NUMBER=   # alias for TWILIO_FROM_NUMBER
# TWILIO_SMS_ENABLED=

# Optional: Expo push for server-triggered notifications (same project as the app)
EXPO_ACCESS_TOKEN=

# Wallet + mobile money (UGX). WALLET_PAYMENTS_STUB=1 skips real Flutterwave HTTP (same effect as FLUTTERWAVE_STUB=1).
WALLET_PAYMENTS_STUB=
WALLET_MOMO_STUB=
WALLET_WITHDRAW_FEE_PCT=0.015

# Legacy direct MTN / Airtel APIs (retired in code; kept for reference / rollback only)
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_SUBSCRIPTION_KEY=
MTN_DISBURSEMENT_KEY=
MTN_API_USER=
MTN_API_KEY=
MTN_ENVIRONMENT=sandbox

AIRTEL_BASE_URL=https://openapi.airtel.africa
AIRTEL_CLIENT_ID=
AIRTEL_CLIENT_SECRET=
AIRTEL_DISBURSE_PIN=
