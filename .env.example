# Copy to .env and fill in (never commit .env).
# Get URL and anon key from Supabase: Project Settings → API.
#
# Production / EAS builds: set the same EXPO_PUBLIC_* values as EAS Secrets
# (see ../DEPLOY.md). Use your deployed API URL — never localhost for store or sideload APKs.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Create a dedicated Auth user (e.g. support@autexa.app) in Supabase Auth and paste its UUID here for realtime chat.
EXPO_PUBLIC_SUPPORT_USER_ID=

# Autexa Node API (see /server). Dev: http://localhost:8787. Production / Render: https://your-service.onrender.com (no trailing slash)
EXPO_PUBLIC_AUTEXA_API_URL=http://localhost:8787

# Public web URL for sharing wallet payment links (e.g. https://your-site.com)
EXPO_PUBLIC_WEB_APP_URL=

# --- Android native builds (`npm run android`) ---
# Native Android build troubleshooting:
#   npm run android:check
#
# "Unable to locate a Java Runtime" → add to ~/.zshrc (Android Studio's JDK):
#   export JAVA_HOME="/Applications/Android Studio.app/Contents/jbr/Contents/Home"
#   export PATH="$PATH:$JAVA_HOME/bin"
# Then open a NEW terminal. Emulators are created in Android Studio → Device Manager (not in React).
#
# Android-only native folder (skips iOS / CocoaPods):
#   npm run prebuild:android
#   npm run android
#
# No Android Studio needed: use Expo Go — `npm start` → scan QR (same Wi‑Fi as your PC).
