{
  "expo": {
    "name": "Autexa",
    "slug": "autexa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./AppIcons/Assets.xcassets/AppIcon.appiconset/1024.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./AppIcons/Assets.xcassets/AppIcon.appiconset/1024.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./AppIcons/android/mipmap-xxxhdpi/ic_launcher.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "POST_NOTIFICATIONS",
        "CAMERA",
        "RECORD_AUDIO",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO"
      ]
    },
    "web": {
      "favicon": "./AppIcons/Assets.xcassets/AppIcon.appiconset/64.png"
    }
  }
}
