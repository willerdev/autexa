# Copy to web/.env.local or web/.env (or web/src/.env — Vite loads both web/ and web/src/).
# Same Supabase project as the mobile app.

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Autexa Node API — required for account hub + admin (no trailing slash).
# Same URL as the mobile app uses (EXPO_PUBLIC_AUTEXA_API_URL) or server PUBLIC_API_BASE_URL.
VITE_AUTEXA_API_URL=http://localhost:8787
#
# If you only set PUBLIC_API_BASE_URL (server-style .env), Vite will use it as a fallback for the web client.
